{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/medical-visa/layout,_N_T_/medical-visa/page,_N_T_/medical-visa"},"segmentPaths":["/_tree","/_full","/medical-visa/__PAGE__","/medical-visa","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/2f4-7bu_b4avd.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/10hl9doanl79t.js\"/><script src=\"/_next/static/chunks/27jktro2p5rq9.js\" async=\"\"></script><script src=\"/_next/static/chunks/352hg3earo7o0.js\" async=\"\"></script><script src=\"/_next/static/chunks/372qajura9dtt.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-24-4cqk2rh9ls.js\" async=\"\"></script><script src=\"/_next/static/chunks/2s5ij6p7395iv.js\" async=\"\"></script><script src=\"/_next/static/chunks/35k-h_1euenzl.js\" async=\"\"></script><script src=\"/_next/static/chunks/2k1psb0-a-uxg.js\" async=\"\"></script><title>Shifa Global Care | Healthcare without borders</title><meta name=\"description\" content=\"International medical tourism coordination for treatment in India.\"/><meta name=\"robots\" content=\"index, follow\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><header class=\"fixed inset-x-0 top-0 z-40 border-b border-slate-200/80 bg-white/90 backdrop-blur-xl\"><div class=\"mx-auto flex h-20 max-w-7xl items-center justify-between px-5 lg:px-8\"><a class=\"flex items-center gap-3\" href=\"/\"><span class=\"grid size-10 place-items-center rounded-xl bg-teal-700 text-xl font-black text-white shadow-lg shadow-teal-900/15\">✚</span><span class=\"leading-tight\"><strong class=\"block font-display text-base text-slate-950\">Shifa Global Care</strong><span class=\"text-[10px] font-bold uppercase tracking-[.18em] text-teal-700\">Solution Limited</span></span></a><nav class=\"hidden items-center gap-6 xl:flex\" aria-label=\"Primary navigation\"><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/about\">About</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/services\">Services</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/treatments\">Treatments</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/hospitals\">Hospitals</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/doctors\">Doctors</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/medical-visa\">Medical Visa</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/blog\">Blog</a></nav><div class=\"hidden items-center gap-4 md:flex\"><a class=\"text-sm font-semibold text-slate-700\" href=\"/contact\">Contact us</a><button class=\"rounded-full bg-teal-700 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-teal-900/20 transition hover:bg-teal-800\">Book consultation</button></div><button class=\"grid size-11 place-items-center rounded-xl border border-slate-200 text-xl md:hidden\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">☰</button></div></header><main class=\"pt-20\"><div class=\"min-h-screen bg-slate-50 py-16 px-6\"><div class=\"mx-auto max-w-7xl\"><header class=\"max-w-3xl mb-12\"><span class=\"text-teal-700 font-bold text-xs uppercase tracking-widest block mb-4\">MEDICAL TRAVEL CONVERSION</span><h1 class=\"text-4xl font-extrabold text-slate-900 tracking-tight sm:text-5xl\">Indian Medical Visa Guidance</h1><p class=\"text-base text-slate-600 mt-4 leading-relaxed\">Obtaining a Medical Visa (MED) is a critical step for your treatment journey. Shifa Global Care guides you through embassy prerequisites, fast-tracks hospital invitation letters, and ensures compliant documentation.</p></header><div class=\"grid gap-12 lg:grid-cols-12 items-start\"><div class=\"lg:col-span-8 space-y-6\"><div class=\"bg-white border border-slate-200 rounded-3xl p-8 shadow-xs\"><h2 class=\"text-xl font-bold text-slate-900 mb-8\">Step-by-Step Visa Coordination</h2><div class=\"grid gap-8\"><div class=\"flex gap-5\"><span class=\"grid size-10 shrink-0 place-items-center rounded-xl bg-teal-50 text-teal-800 text-sm font-extrabold\">01</span><div><h3 class=\"font-bold text-slate-900 text-sm md:text-base\">Receive Hospital invitation Letter</h3><p class=\"text-xs text-slate-500 mt-2 leading-relaxed\">Our team coordinates with the selected partner hospital in India to issue an official Medical Visa Invitation Letter detailing your clinical booking and estimated stay duration.</p></div></div><div class=\"flex gap-5\"><span class=\"grid size-10 shrink-0 place-items-center rounded-xl bg-teal-50 text-teal-800 text-sm font-extrabold\">02</span><div><h3 class=\"font-bold text-slate-900 text-sm md:text-base\">Embassy Application Submission</h3><p class=\"text-xs text-slate-500 mt-2 leading-relaxed\">Submit your online visa application on the official government portal. We review your document attachments (passport scans, native doctor referrals, bank statements) to prevent administrative delays.</p></div></div><div class=\"flex gap-5\"><span class=\"grid size-10 shrink-0 place-items-center rounded-xl bg-teal-50 text-teal-800 text-sm font-extrabold\">03</span><div><h3 class=\"font-bold text-slate-900 text-sm md:text-base\">IVAC Biometrics &amp; processing</h3><p class=\"text-xs text-slate-500 mt-2 leading-relaxed\">Attend your biometric appointment at the local Indian Visa Application Center (IVAC) in Bangladesh or your home country. Medical visas are fast-tracked compared to tourist visas.</p></div></div><div class=\"flex gap-5\"><span class=\"grid size-10 shrink-0 place-items-center rounded-xl bg-teal-50 text-teal-800 text-sm font-extrabold\">04</span><div><h3 class=\"font-bold text-slate-900 text-sm md:text-base\">Attendant Visa Coordinates</h3><p class=\"text-xs text-slate-500 mt-2 leading-relaxed\">India allows up to two companions to travel under Medical Attendant (MED-2) visas. We assist in filing these companion applications concurrently with the patient&#x27;s request.</p></div></div></div></div></div><div class=\"lg:col-span-4 space-y-6\"><div class=\"bg-white border border-slate-200 rounded-3xl p-8 shadow-xs\"><h2 class=\"text-base font-bold text-slate-900 mb-6\">Required Attachments</h2><ul class=\"space-y-4\"><li class=\"border-b border-slate-100 pb-3 last:border-0 last:pb-0\"><strong class=\"text-xs text-slate-800 font-semibold block\">Accredited Hospital Invitation Letter</strong><span class=\"text-4xs text-slate-400 block mt-0.5 leading-relaxed\">Issued by our Indian partner hospital desk (we manage this).</span></li><li class=\"border-b border-slate-100 pb-3 last:border-0 last:pb-0\"><strong class=\"text-xs text-slate-800 font-semibold block\">Native Referral Letter</strong><span class=\"text-4xs text-slate-400 block mt-0.5 leading-relaxed\">Recommendation summary from a registered doctor in your home country.</span></li><li class=\"border-b border-slate-100 pb-3 last:border-0 last:pb-0\"><strong class=\"text-xs text-slate-800 font-semibold block\">Valid Passport</strong><span class=\"text-4xs text-slate-400 block mt-0.5 leading-relaxed\">Must have at least 6 months remaining validity with 2 blank pages.</span></li><li class=\"border-b border-slate-100 pb-3 last:border-0 last:pb-0\"><strong class=\"text-xs text-slate-800 font-semibold block\">Financial Solvency proof</strong><span class=\"text-4xs text-slate-400 block mt-0.5 leading-relaxed\">Recent bank statements showing adequate funds for clinical and stay budgets.</span></li><li class=\"border-b border-slate-100 pb-3 last:border-0 last:pb-0\"><strong class=\"text-xs text-slate-800 font-semibold block\">Passport Sized Photographs</strong><span class=\"text-4xs text-slate-400 block mt-0.5 leading-relaxed\">Recent color photographs matching Indian visa size guidelines.</span></li><li class=\"border-b border-slate-100 pb-3 last:border-0 last:pb-0\"><strong class=\"text-xs text-slate-800 font-semibold block\">Utility Bill Copy</strong><span class=\"text-4xs text-slate-400 block mt-0.5 leading-relaxed\">National residency proof matching your current address details.</span></li></ul></div><div class=\"bg-teal-900 text-white rounded-3xl p-6 shadow-sm relative overflow-hidden\"><div class=\"absolute inset-0 bg-[radial-gradient(circle_at_75%_20%,rgba(20,184,166,0.15),transparent_25%)]\"></div><h3 class=\"font-bold text-sm mb-2 relative z-10\">Need a Visa invitation Letter?</h3><p class=\"text-xs text-teal-100/90 leading-relaxed mb-6 relative z-10\">Submit your case consultation. Once matched, we will initiate request procedures for your embassy letter with Apollo, Fortis, or Medanta desks.</p><button class=\"w-full bg-white text-teal-900 font-bold text-xs py-3 rounded-xl shadow-md hover:bg-slate-50 transition cursor-pointer relative z-10\">Start Visa Request</button></div></div></div></div></div><!--$--><!--/$--></main><footer class=\"bg-slate-950 text-slate-300\"><div class=\"mx-auto grid max-w-7xl gap-10 px-5 py-14 lg:grid-cols-[1.4fr_1fr_1fr_1fr] lg:px-8\"><div><div class=\"flex items-center gap-3 text-white\"><span class=\"grid size-10 place-items-center rounded-xl bg-teal-500 text-xl font-black\">✚</span><strong class=\"font-display\">Shifa Global Care</strong></div><p class=\"mt-5 max-w-sm text-sm leading-6 text-slate-400\">Advancing Healthcare. Building Trust. Transforming Lives.<!-- --> We help international patients navigate treatment in India with clarity, dignity, and ongoing support.</p></div><div><h2 class=\"text-sm font-bold text-white\">Explore</h2><div class=\"mt-4 grid gap-3 text-sm\"><a class=\"hover:text-teal-300\" href=\"/about\">About</a><a class=\"hover:text-teal-300\" href=\"/services\">Services</a><a class=\"hover:text-teal-300\" href=\"/treatments\">Treatments</a><a class=\"hover:text-teal-300\" href=\"/hospitals\">Hospitals</a></div></div><div><h2 class=\"text-sm font-bold text-white\">Patient support</h2><div class=\"mt-4 grid gap-3 text-sm\"><a class=\"hover:text-teal-300\" href=\"/medical-visa\">Medical visa</a><a class=\"hover:text-teal-300\" href=\"/faq\">Frequently asked questions</a><a class=\"hover:text-teal-300\" href=\"/contact\">Contact care team</a></div></div><div><h2 class=\"text-sm font-bold text-white\">Important note</h2><p class=\"mt-4 text-sm leading-6 text-slate-400\">Shifa coordinates care but does not replace advice from a licensed clinician. For urgent symptoms, seek local emergency care.</p></div></div><div class=\"border-t border-white/10\"><div class=\"mx-auto flex max-w-7xl flex-col gap-3 px-5 py-5 text-xs text-slate-500 sm:flex-row sm:justify-between lg:px-8\"><span>© <!-- -->2026<!-- --> Shifa Global Care Solution Limited.</span><span><a class=\"hover:text-white\" href=\"/privacy-policy\">Privacy</a> · <a class=\"hover:text-white\" href=\"/terms\">Terms</a></span></div></div></footer><script src=\"/_next/static/chunks/10hl9doanl79t.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[70119,[\\\"/_next/static/chunks/2s5ij6p7395iv.js\\\",\\\"/_next/static/chunks/35k-h_1euenzl.js\\\"],\\\"default\\\"]\\n3:I[39756,[\\\"/_next/static/chunks/2s5ij6p7395iv.js\\\",\\\"/_next/static/chunks/35k-h_1euenzl.js\\\"],\\\"default\\\"]\\n4:I[37457,[\\\"/_next/static/chunks/2s5ij6p7395iv.js\\\",\\\"/_next/static/chunks/35k-h_1euenzl.js\\\"],\\\"default\\\"]\\n5:I[22016,[\\\"/_next/static/chunks/2s5ij6p7395iv.js\\\",\\\"/_next/static/chunks/35k-h_