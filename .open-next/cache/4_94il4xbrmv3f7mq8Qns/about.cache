{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/about/layout,_N_T_/about/page,_N_T_/about"},"segmentPaths":["/_tree","/_full","/about/__PAGE__","/about","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/2f4-7bu_b4avd.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/10hl9doanl79t.js\"/><script src=\"/_next/static/chunks/27jktro2p5rq9.js\" async=\"\"></script><script src=\"/_next/static/chunks/352hg3earo7o0.js\" async=\"\"></script><script src=\"/_next/static/chunks/372qajura9dtt.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-24-4cqk2rh9ls.js\" async=\"\"></script><script src=\"/_next/static/chunks/2s5ij6p7395iv.js\" async=\"\"></script><script src=\"/_next/static/chunks/35k-h_1euenzl.js\" async=\"\"></script><script src=\"/_next/static/chunks/3ioe55naf036m.js\" async=\"\"></script><title>Shifa Global Care | Healthcare without borders</title><meta name=\"description\" content=\"International medical tourism coordination for treatment in India.\"/><meta name=\"robots\" content=\"index, follow\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><header class=\"fixed inset-x-0 top-0 z-40 border-b border-slate-200/80 bg-white/90 backdrop-blur-xl\"><div class=\"mx-auto flex h-20 max-w-7xl items-center justify-between px-5 lg:px-8\"><a class=\"flex items-center gap-3\" href=\"/\"><span class=\"grid size-10 place-items-center rounded-xl bg-teal-700 text-xl font-black text-white shadow-lg shadow-teal-900/15\">✚</span><span class=\"leading-tight\"><strong class=\"block font-display text-base text-slate-950\">Shifa Global Care</strong><span class=\"text-[10px] font-bold uppercase tracking-[.18em] text-teal-700\">Solution Limited</span></span></a><nav class=\"hidden items-center gap-6 xl:flex\" aria-label=\"Primary navigation\"><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/about\">About</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/services\">Services</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/treatments\">Treatments</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/hospitals\">Hospitals</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/doctors\">Doctors</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/medical-visa\">Medical Visa</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/blog\">Blog</a></nav><div class=\"hidden items-center gap-4 md:flex\"><a class=\"text-sm font-semibold text-slate-700\" href=\"/contact\">Contact us</a><button class=\"rounded-full bg-teal-700 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-teal-900/20 transition hover:bg-teal-800\">Book consultation</button></div><button class=\"grid size-11 place-items-center rounded-xl border border-slate-200 text-xl md:hidden\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">☰</button></div></header><main class=\"pt-20\"><div class=\"flex flex-col w-full bg-slate-50 min-h-screen\"><section class=\"mx-auto max-w-7xl px-5 py-20 lg:px-8 relative z-10\"><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-16 items-center\"><div class=\"reveal transition duration-700 ease-out transform opacity-0 translate-y-4\"><span class=\"text-teal-700 font-bold text-xs uppercase tracking-widest block mb-4\">ABOUT SHIFA GLOBAL CARE</span><h1 class=\"text-4xl sm:text-5xl font-extrabold text-slate-900 leading-tight mb-6\">Advancing Healthcare. Building Trust.</h1><p class=\"text-base text-slate-600 leading-relaxed mb-8\">Shifa Global Care Solution Limited is a trusted medical tourism facilitator connecting international patients with leading hospitals and specialists in India.<!-- --> <!-- -->Since 2007, we have helped patients from Bangladesh and other countries access advanced, affordable, and life-saving treatment with confidence and peace of mind.</p><div class=\"grid grid-cols-2 gap-8 pt-6 border-t border-slate-200\"><div class=\"space-y-2\"><h3 class=\"font-bold text-teal-800 text-base\">Our Mission</h3><p class=\"text-slate-500 text-xs leading-relaxed\">To provide seamless medical tourism services through professional excellence, personalized patient care, and strong partnerships with leading hospitals.</p></div><div class=\"space-y-2\"><h3 class=\"font-bold text-sky-800 text-base\">Our Vision</h3><p class=\"text-slate-500 text-xs leading-relaxed\">To be the most trusted international healthcare facilitator connecting patients with world-class medical expertise while making healthcare more accessible, affordable, and compassionate.</p></div></div></div><div class=\"relative aspect-4/3 rounded-3xl overflow-hidden shadow-2xl reveal transition duration-700 delay-100 ease-out transform opacity-0 translate-y-4 bg-slate-200\"><img alt=\"Medical team consulting\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 768px) 100vw, 50vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1582213782179-e0d53f98f2ca%3Fauto%3Dformat%26fit%3Dcrop%26w%3D800%26q%3D80&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1582213782179-e0d53f98f2ca%3Fauto%3Dformat%26fit%3Dcrop%26w%3D800%26q%3D80&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1582213782179-e0d53f98f2ca%3Fauto%3Dformat%26fit%3Dcrop%26w%3D800%26q%3D80&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1582213782179-e0d53f98f2ca%3Fauto%3Dformat%26fit%3Dcrop%26w%3D800%26q%3D80&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1582213782179-e0d53f98f2ca%3Fauto%3Dformat%26fit%3Dcrop%26w%3D800%26q%3D80&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1582213782179-e0d53f98f2ca%3Fauto%3Dformat%26fit%3Dcrop%26w%3D800%26q%3D80&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1582213782179-e0d53f98f2ca%3Fauto%3Dformat%26fit%3Dcrop%26w%3D800%26q%3D80&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1582213782179-e0d53f98f2ca%3Fauto%3Dformat%26fit%3Dcrop%26w%3D800%26q%3D80&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1582213782179-e0d53f98f2ca%3Fauto%3Dformat%26fit%3Dcrop%26w%3D800%26q%3D80&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1582213782179-e0d53f98f2ca%3Fauto%3Dformat%26fit%3Dcrop%26w%3D800%26q%3D80&amp;w=3840&amp;q=75\"/></div></div></section><section class=\"bg-white border-y border-slate-200/80 py-20\"><div class=\"mx-auto max-w-7xl px-5 lg:px-8\"><div class=\"text-center max-w-2xl mx-auto mb-16 reveal transition duration-700 ease-out transform opacity-0 translate-y-4\"><h2 class=\"text-3xl font-extrabold text-slate-900\">Our Core Values</h2><p class=\"text-sm text-slate-500 mt-4 leading-relaxed\">We operate under a strict code of ethics, focusing entirely on facilitating optimal clinical outcomes with absolute transparency.</p></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\"><div class=\"bg-slate-50 border border-slate-200 rounded-3xl p-8 shadow-xs hover:shadow-md transition reveal duration-700 ease-out transform opacity-0 translate-y-4\" style=\"transition-delay:0ms\"><div class=\"size-12 rounded-2xl bg-teal-50 text-teal-700 flex items-center justify-center text-xl font-bold mb-6 shadow-inner\">⚖️</div><h3 class=\"text-lg font-bold text-slate-900 mb-3\">Unwavering Ethics</h3><p class=\"text-xs text-slate-500 leading-relaxed\">We prioritize medical integrity above all else, ensuring unbiased advice and strictly confidential patient data management.</p></div><div class=\"bg-slate-50 border border-slate-200 rounded-3xl p-8 shadow-xs hover:shadow-md transition reveal duration-700 ease-out transform opacity-0 translate-y-4\" style=\"transition-delay:100ms\"><div class=\"size-12 rounded-2xl bg-sky-50 text-sky-700 flex items-center justify-center text-xl font-bold mb-6 shadow-inner\">✓</div><h3 class=\"text-lg font-bold text-slate-900 mb-3\">Clinical Quality</h3><p class=\"text-xs text-slate-500 leading-relaxed\">Our network is restricted to accredited institutions and specialists with proven track records of clinical excellence.</p></div><div class=\"bg-slate-50 border border-slate-200 rounded-3xl p-8 shadow-xs hover:shadow-md transition reveal duration-700 ease-out transform opacity-0 translate-y-4\" style=\"transition-delay:200ms\"><div class=\"size-12 rounded-2xl bg-teal-50 text-teal-700 flex items-center justify-center text-xl font-bold mb-6 shadow-inner\">🤝</div><h3 class=\"text-lg font-bold text-slate-900 mb-3\">Patient-First Approach</h3><p class=\"text-xs text-slate-500 leading-relaxed\">Every decision starts and ends with the patient&#x27;s well-being, comfort, and personalized healthcare journey.</p></div></div></div></section><section class=\"mx-auto max-w-7xl px-5 py-20 lg:px-8\"><div class=\"text-center max-w-2xl mx-auto mb-16 reveal transition duration-700 ease-out transform opacity-0 translate-y-4\"><h2 class=\"text-3xl font-extrabold text-slate-900\">Nearly Two Decades of Care</h2><p class=\"text-sm text-slate-500 mt-4 leading-relaxed\">Since 2007, we have walked alongside patients to provide security, transparency, and hope.</p></div><div class=\"relative border-l border-slate-200/85 ml-4 md:ml-32 space-y-12\"><div class=\"relative pl-8 md:pl-12 reveal transition duration-700 ease-out transform opacity-0 translate-y-4\"><div class=\"absolute -left-3 top-1.5 size-6 rounded-full border-4 border-white bg-teal-700 shadow-sm\"></div><div class=\"absolute -left-4 md:-left-32 top-1.5 text-lg font-extrabold text-slate-900\">2007</div><div class=\"bg-white border border-slate-200 rounded-3xl p-6 shadow-xs max-w-2xl\"><h3 class=\"text-base font-bold text-slate-950\">The Inception</h3><p class=\"text-xs text-slate-500 mt-2 leading-relaxed\">Founded Shifa Global Care to simplify cross-border medical travel and hospital coordination for international patients.</p></div></div><div class=\"relative pl-8 md:pl-12 reveal transition duration-700 ease-out transform opacity-0 translate-y-4\"><div class=\"absolute -left-3 top-1.5 size-6 rounded-full border-4 border-white bg-sky-700 shadow-sm\"></div><div class=\"absolute -left-4 md:-left-32 top-1.5 text-lg font-extrabold text-slate-900\">2012</div><div class=\"bg-white border border-slate-200 rounded-3xl p-6 shadow-xs max-w-2xl\"><h3 class=\"text-base font-bold text-slate-950\">Bangladeshi Liaison Office</h3><p class=\"text-xs text-slate-500 mt-2 leading-relaxed\">Established dedicated offices to streamline visas and case evaluations for patients traveling from Bangladesh.</p></div></div><div class=\"relative pl-8 md:pl-12 reveal transition duration-700 ease-out transform opacity-0 translate-y-4\"><div class=\"absolute -left-3 top-1.5 size-6 rounded-full border-4 border-white bg-teal-700 shadow-sm\"></div><div class=\"absolute -left-4 md:-left-32 top-1.5 text-lg font-extrabold text-slate-900\">2018</div><div class=\"bg-white border border-slate-200 rounded-3xl p-6 shadow-xs max-w-2xl\"><h3 class=\"text-base font-bold text-slate-950\">Hospital Network Expansion</h3><p class=\"text-xs text-slate-500 mt-2 leading-relaxed\">Partnered with over 50 leading JCI-accredited hospitals across major Indian cities (Delhi, Chennai, Mumbai, Bangalore).</p></div></div><div class=\"relative pl-8 md:pl-12 reveal transition duration-700 ease-out transform opacity-0 translate-y-4\"><div class=\"absolute -left-3 top-1.5 size-6 rounded-full border-4 border-white bg-sky-700 shadow-sm\"></div><div class=\"absolute -left-4 md:-left-32 top-1.5 text-lg font-extrabold text-slate-900\">2026</div><div class=\"bg-white border border-slate-200 rounded-3xl p-6 shadow-xs max-w-2xl\"><h3 class=\"text-base font-bold text-slate-950\">Trusted Facilitation</h3><p class=\"text-xs text-slate-500 mt-2 leading-relaxed\">Over 10,000+ patients assisted globally with seamless visa support, case evaluation, and compassionate coordinates.</p></div></div></div></section><section class=\"bg-white border-t border-slate-200/80 py-20\"><div class=\"mx-auto max-w-7xl px-5 lg:px-8\"><div class=\"text-center max-w-2xl mx-auto mb-16 reveal transition duration-700 ease-out transform opacity-0 translate-y-4\"><h2 class=\"text-3xl font-extrabold text-slate-900\">Our Leadership Team</h2><p class=\"text-sm text-slate-500 mt-4 leading-relaxed\">Meet the healthcare professionals and visa facilitation coordinators behind Shifa Global Care.</p></div><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8\"><div class=\"group cursor-pointer bg-slate-50 border rounded-3xl overflow-hidden transition-all duration-300 reveal border-slate-200 hover:border-slate-300 shadow-xs\" style=\"transition-delay:0ms\"><div class=\"relative aspect-square bg-slate-200 overflow-hidden\"><img alt=\"Mr. Farhan Shafi\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover group-hover:scale-105 transition-transform duration-500\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 640px) 100vw, 25vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=256&amp;q=75 256w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1560250097-0b93528c311a%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=3840&amp;q=75\"/></div><div class=\"p-5\"><h3 class=\"font-bold text-slate-900 text-sm\">Mr. Farhan Shafi</h3><p class=\"text-teal-700 text-2xs font-bold uppercase tracking-wider mt-1\">CEO &amp; Founder</p><div class=\"transition-all duration-300 overflow-hidden max-h-0 opacity-0\"><p class=\"text-4xs text-slate-500 leading-relaxed border-t border-slate-200 pt-3\">Farhan has over 18 years of cross-border medical tourism leadership, dedicating his career to making advanced care accessible and affordable.</p></div><div class=\"text-teal-700 text-4xs font-bold mt-4 flex items-center justify-end\">Show bio ▼</div></div></div><div class=\"group cursor-pointer bg-slate-50 border rounded-3xl overflow-hidden transition-all duration-300 reveal border-slate-200 hover:border-slate-300 shadow-xs\" style=\"transition-delay:100ms\"><div class=\"relative aspect-square bg-slate-200 overflow-hidden\"><img alt=\"Dr. Sarah Khalil\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover group-hover:scale-105 transition-transform duration-500\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 640px) 100vw, 25vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=256&amp;q=75 256w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=3840&amp;q=75\"/></div><div class=\"p-5\"><h3 class=\"font-bold text-slate-900 text-sm\">Dr. Sarah Khalil</h3><p class=\"text-teal-700 text-2xs font-bold uppercase tracking-wider mt-1\">Chief Medical Adviser</p><div class=\"transition-all duration-300 overflow-hidden max-h-0 opacity-0\"><p class=\"text-4xs text-slate-500 leading-relaxed border-t border-slate-200 pt-3\">Dr. Sarah Khalil oversees our clinical board reviews, ensuring that each patient&#x27;s medical history is accurately evaluated and matched with the absolute best-fit specialists in India.</p></div><div class=\"text-teal-700 text-4xs font-bold mt-4 flex items-center justify-end\">Show bio ▼</div></div></div><div class=\"group cursor-pointer bg-slate-50 border rounded-3xl overflow-hidden transition-all duration-300 reveal border-slate-200 hover:border-slate-300 shadow-xs\" style=\"transition-delay:200ms\"><div class=\"relative aspect-square bg-slate-200 overflow-hidden\"><img alt=\"Ms. Jannat Ara\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover group-hover:scale-105 transition-transform duration-500\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 640px) 100vw, 25vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1580489944761-15a19d654956%3Fauto%3Dformat%26fit%3Dcrop%26w%3D400%26q%3D80&amp;w=25