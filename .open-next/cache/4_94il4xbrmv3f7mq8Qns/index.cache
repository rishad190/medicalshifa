{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/,_N_T_/index"},"segmentPaths":["/_tree","/_full","/__PAGE__","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/2f4-7bu_b4avd.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/10hl9doanl79t.js\"/><script src=\"/_next/static/chunks/27jktro2p5rq9.js\" async=\"\"></script><script src=\"/_next/static/chunks/352hg3earo7o0.js\" async=\"\"></script><script src=\"/_next/static/chunks/372qajura9dtt.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-24-4cqk2rh9ls.js\" async=\"\"></script><script src=\"/_next/static/chunks/2s5ij6p7395iv.js\" async=\"\"></script><script src=\"/_next/static/chunks/35k-h_1euenzl.js\" async=\"\"></script><title>Shifa Global Care | Healthcare without borders</title><meta name=\"description\" content=\"International medical tourism coordination for treatment in India.\"/><meta name=\"robots\" content=\"index, follow\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><header class=\"fixed inset-x-0 top-0 z-40 border-b border-slate-200/80 bg-white/90 backdrop-blur-xl\"><div class=\"mx-auto flex h-20 max-w-7xl items-center justify-between px-5 lg:px-8\"><a class=\"flex items-center gap-3\" href=\"/\"><span class=\"grid size-10 place-items-center rounded-xl bg-teal-700 text-xl font-black text-white shadow-lg shadow-teal-900/15\">✚</span><span class=\"leading-tight\"><strong class=\"block font-display text-base text-slate-950\">Shifa Global Care</strong><span class=\"text-[10px] font-bold uppercase tracking-[.18em] text-teal-700\">Solution Limited</span></span></a><nav class=\"hidden items-center gap-6 xl:flex\" aria-label=\"Primary navigation\"><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/about\">About</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/services\">Services</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/treatments\">Treatments</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/hospitals\">Hospitals</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/doctors\">Doctors</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/medical-visa\">Medical Visa</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/blog\">Blog</a></nav><div class=\"hidden items-center gap-4 md:flex\"><a class=\"text-sm font-semibold text-slate-700\" href=\"/contact\">Contact us</a><button class=\"rounded-full bg-teal-700 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-teal-900/20 transition hover:bg-teal-800\">Book consultation</button></div><button class=\"grid size-11 place-items-center rounded-xl border border-slate-200 text-xl md:hidden\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">☰</button></div></header><main class=\"pt-20\"><section class=\"relative isolate overflow-hidden bg-slate-950 text-white\"><div class=\"absolute inset-0 bg-[radial-gradient(circle_at_75%_20%,rgba(20,184,166,.28),transparent_28%),radial-gradient(circle_at_20%_85%,rgba(59,130,246,.20),transparent_30%)]\"></div><div class=\"relative mx-auto grid max-w-7xl gap-14 px-5 py-20 sm:py-28 lg:grid-cols-[1.1fr_.9fr] lg:px-8 lg:py-32\"><div class=\"max-w-2xl\"><p class=\"mb-6 inline-flex items-center gap-2 rounded-full border border-teal-300/25 bg-white/5 px-4 py-2 text-xs font-bold uppercase tracking-[.16em] text-teal-200\"><span class=\"size-2 rounded-full bg-teal-300\"></span> Established 2007 · India care coordination</p><h1 class=\"font-display text-5xl font-semibold leading-[1.06] tracking-tight sm:text-6xl\">Healthcare without <span class=\"text-teal-300\">borders.</span></h1><p class=\"mt-7 max-w-xl text-lg leading-8 text-slate-300\">Shifa Global Care Solution Limited is a trusted medical tourism facilitator connecting international patients with leading hospitals and specialists in India.<!-- --> We make the path to treatment in India easier to understand, arrange, and manage.</p><div class=\"mt-10 flex flex-wrap gap-4\"><a class=\"rounded-full bg-teal-400 px-6 py-3.5 text-sm font-bold text-teal-950 transition hover:bg-teal-300\" href=\"/contact\">Discuss your case <span aria-hidden=\"true\">→</span></a><a class=\"rounded-full border border-white/25 px-6 py-3.5 text-sm font-bold text-white transition hover:bg-white/10\" href=\"/services\">Explore our services</a></div><p class=\"mt-8 text-sm text-slate-400\">Private case guidance · Personalized planning · Patient-first coordination</p></div><div class=\"relative mx-auto w-full max-w-md self-center\"><div class=\"rounded-[2rem] border border-white/15 bg-white/10 p-6 shadow-2xl backdrop-blur\"><div class=\"flex items-center justify-between\"><span class=\"text-sm font-bold\">Your care pathway</span><span class=\"rounded-full bg-teal-300/15 px-3 py-1 text-xs font-bold text-teal-200\">Guided</span></div><div class=\"mt-8 grid gap-5\"><div class=\"flex gap-4\"><span class=\"grid size-9 shrink-0 place-items-center rounded-full bg-white text-sm font-bold text-teal-800\">1</span><div><h2 class=\"font-semibold\">Initial consultation</h2><p class=\"mt-1 text-sm leading-5 text-slate-300\">Share your medical history and goals with our care coordinators.</p></div></div><div class=\"flex gap-4\"><span class=\"grid size-9 shrink-0 place-items-center rounded-full bg-white text-sm font-bold text-teal-800\">2</span><div><h2 class=\"font-semibold\">Specialist matching</h2><p class=\"mt-1 text-sm leading-5 text-slate-300\">We identify hospitals and doctors aligned to your needs and budget.</p></div></div><div class=\"flex gap-4\"><span class=\"grid size-9 shrink-0 place-items-center rounded-full bg-white text-sm font-bold text-teal-800\">3</span><div><h2 class=\"font-semibold\">Travel &amp; treatment coordination</h2><p class=\"mt-1 text-sm leading-5 text-slate-300\">We arrange appointments, visas, lodging, and transfers so you can focus on recovery.</p></div></div><div class=\"flex gap-4\"><span class=\"grid size-9 shrink-0 place-items-center rounded-full bg-white text-sm font-bold text-teal-800\">4</span><div><h2 class=\"font-semibold\">Follow-up support</h2><p class=\"mt-1 text-sm leading-5 text-slate-300\">We remain available for post-treatment care and continued guidance.</p></div></div></div></div><div class=\"absolute -bottom-6 -left-6 rounded-2xl border border-slate-200 bg-white p-4 text-slate-900 shadow-xl\"><p class=\"text-2xl font-bold text-teal-700\">18+ years</p><p class=\"text-xs font-medium text-slate-500\">of cross-border care support</p></div></div></div></section><section class=\"border-b border-slate-200 bg-white\"><div class=\"mx-auto grid max-w-7xl grid-cols-2 gap-y-7 px-5 py-8 sm:grid-cols-4 lg:px-8\"><div class=\"border-slate-200 px-4 text-center sm:border-r last:border-0\"><strong class=\"font-display text-2xl text-teal-800\">10k+</strong><p class=\"mt-1 text-xs font-medium text-slate-500\">Patients assisted</p></div><div class=\"border-slate-200 px-4 text-center sm:border-r last:border-0\"><strong class=\"font-display text-2xl text-teal-800\">500+</strong><p class=\"mt-1 text-xs font-medium text-slate-500\">Specialists partnered</p></div><div class=\"border-slate-200 px-4 text-center sm:border-r last:border-0\"><strong class=\"font-display text-2xl text-teal-800\">25+</strong><p class=\"mt-1 text-xs font-medium text-slate-500\">Countries served</p></div><div class=\"border-slate-200 px-4 text-center sm:border-r last:border-0\"><strong class=\"font-display text-2xl text-teal-800\">15 min</strong><p class=\"mt-1 text-xs font-medium text-slate-500\">Average response time</p></div></div></section><section class=\"mx-auto max-w-7xl px-5 py-20 lg:px-8\"><div class=\"max-w-2xl\"><p class=\"text-sm font-bold uppercase tracking-[.16em] text-teal-700\">Why Shifa Global Care</p><h2 class=\"mt-3 font-display text-4xl font-semibold tracking-tight text-slate-950\">A composed, compassionate path through complex care.</h2></div><div class=\"mt-12 grid gap-5 md:grid-cols-3\"><article class=\"rounded-3xl border border-slate-200 bg-white p-7 shadow-sm\"><span class=\"text-sm font-bold text-teal-700\">01</span><h3 class=\"mt-10 font-display text-xl font-bold text-slate-900\">Clinical fit, not sales pressure</h3><p class=\"mt-3 text-sm leading-6 text-slate-600\">Your case is matched around clinical needs, preferences, and a clear understanding of the next step.</p></article><article class=\"rounded-3xl border border-slate-200 bg-white p-7 shadow-sm\"><span class=\"text-sm font-bold text-teal-700\">02</span><h3 class=\"mt-10 font-display text-xl font-bold text-slate-900\">One dedicated coordinator</h3><p class=\"mt-3 text-sm leading-6 text-slate-600\">From medical records to airport arrival, one care coordinator keeps every part of your journey connected.</p></article><article class=\"rounded-3xl border border-slate-200 bg-white p-7 shadow-sm\"><span class=\"text-sm font-bold text-teal-700\">03</span><h3 class=\"mt-10 font-display text-xl font-bold text-slate-900\">Support before and after travel</h3><p class=\"mt-3 text-sm leading-6 text-slate-600\">We remain available for follow-up planning and communication after you return home.</p></article></div></section><section class=\"bg-teal-50/60 py-20\"><div class=\"mx-auto max-w-7xl px-5 lg:px-8\"><div class=\"flex flex-wrap items-end justify-between gap-5\"><div><p class=\"text-sm font-bold uppercase tracking-[.16em] text-teal-700\">Care that fits your needs</p><h2 class=\"mt-3 font-display text-4xl font-semibold tracking-tight text-slate-950\">From first records to follow-up.</h2></div><a class=\"text-sm font-bold text-teal-800 hover:text-teal-600\" href=\"/services\">All services →</a></div><div class=\"mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4\"><article class=\"rounded-2xl bg-white p-6\"><span class=\"grid size-10 place-items-center rounded-xl bg-teal-100 font-bold text-teal-800\">1</span><h3 class=\"mt-6 font-display text-lg font-bold text-slate-900\">Medical Consultation</h3><p class=\"mt-3 text-sm leading-6 text-slate-600\">Expert case evaluation, treatment planning, and second-opinion support.</p></article><article class=\"rounded-2xl bg-white p-6\"><span class=\"grid size-10 place-items-center rounded-xl bg-teal-100 font-bold text-teal-800\">2</span><h3 class=\"mt-6 font-display text-lg font-bold text-slate-900\">Hospital &amp; Specialist Selection</h3><p class=\"mt-3 text-sm leading-6 text-slate-600\">We connect patients with accredited hospitals and leading physicians.</p></article><article class=\"rounded-2xl bg-white p-6\"><span class=\"grid size-10 place-items-center rounded-xl bg-teal-100 font-bold text-teal-800\">3</span><h3 class=\"mt-6 font-display text-lg font-bold text-slate-900\">Visa &amp; Travel Assistance</h3><p class=\"mt-3 text-sm leading-6 text-slate-600\">Support for medical visas, travel coordination, and local logistics.</p></article><article class=\"rounded-2xl bg-white p-6\"><span class=\"grid size-10 place-items-center rounded-xl bg-teal-100 font-bold text-teal-800\">4</span><h3 class=\"mt-6 font-display text-lg font-bold text-slate-900\">Interpreter &amp; Follow-Up Care</h3><p class=\"mt-3 text-sm leading-6 text-slate-600\">Language support and post-treatment coordination for a smoother journey.</p></article></div></div></section><section class=\"mx-auto max-w-7xl px-5 py-20 lg:px-8\"><div class=\"grid gap-10 lg:grid-cols-[.75fr_1.25fr]\"><div><p class=\"text-sm font-bold uppercase tracking-[.16em] text-teal-700\">Specialty pathways</p><h2 class=\"mt-3 font-display text-4xl font-semibold tracking-tight text-slate-950\">Expertise for the care that matters most.</h2><p class=\"mt-5 text-sm leading-6 text-slate-600\">Our team coordinates treatment pathways across major medical specialties, collaborating with leading hospitals and specialists in India.</p><a class=\"mt-7 inline-block text-sm font-bold text-teal-800\" href=\"/treatments\">See treatment areas →</a></div><div class=\"grid grid-cols-2 gap-3 sm:grid-cols-3\"><div class=\"rounded-xl border border-slate-200 bg-white px-4 py-5 text-sm font-semibold text-slate-700\">Cardiology</div><div class=\"rounded-xl border border-slate-200 bg-white px-4 py-5 text-sm font-semibold text-slate-700\">Oncology</div><div class=\"rounded-xl border border-slate-200 bg-white px-4 py-5 text-sm font-semibold text-slate-700\">Organ Transplantation</div><div class=\"rounded-xl border border-slate-200 bg-white px-4 py-5 text-sm font-semibold text-slate-700\">Neurology</div><div class=\"rounded-xl border border-slate-200 bg-white px-4 py-5 text-sm font-semibold text-slate-700\">Neurosurgery</div><div class=\"rounded-xl border border-slate-200 bg-white px-4 py-5 text-sm font-semibold text-slate-700\">Orthopedics</div><div class=\"rounded-xl border border-slate-200 bg-white px-4 py-5 text-sm font-semibold text-slate-700\">Joint Replacement</div><div class=\"rounded-xl border border-slate-200 bg-white px-4 py-5 text-sm font-semibold text-slate-700\">Gastroenterology</div><div class=\"rounded-xl border border-slate-200 bg-white px-4 py-5 text-sm font-semibold text-slate-700\">Nephrology</div><div class=\"rounded-xl border border-slate-200 bg-white px-4 py-5 text-sm font-semibold text-slate-700\">Fertility &amp; IVF</div><div class=\"rounded-xl border border-slate-200 bg-white px-4 py-5 text-sm font-semibold text-slate-700\">Cosmetic Surgery</div><div class=\"rounded-xl border border-slate-200 bg-white px-4 py-5 text-sm font-semibold text-slate-700\">Pediatrics</div><div class=\"rounded-xl border border-slate-200 bg-white px-4 py-5 text-sm font-semibold text-slate-700\">Vision</div></div></div></section><section class=\"bg-slate-950 py-20 text-white\"><div class=\"mx-auto max-w-7xl px-5 lg:px-8\"><div class=\"max-w-xl\"><p class=\"text-sm font-bold uppercase tracking-[.16em] text-teal-300\">Patient voices</p><h2 class=\"mt-3 font-display text-4xl font-semibold tracking-tight\">Supported at every step.</h2></div><div class=\"mt-10 grid gap-5 md:grid-cols-3\"><figure class=\"rounded-2xl border border-white/10 bg-white/5 p-7\"><blockquote class=\"text-sm leading-7 text-slate-200\">“<!-- -->Shifa Global Care guided our family with clarity, compassion, and remarkable coordination from the first call to treatment day.<!-- -->”</blockquote><figcaption class=\"mt-6 text-sm font-bold text-teal-200\">Elena Rodriguez<span class=\"block pt-1 text-xs font-normal text-slate-400\">Cardiology patient, Spain</span></figcaption></figure><figure class=\"rounded-2xl border border-white/10 bg-white/5 p-7\"><blockquote class=\"text-sm leading-7 text-slate-200\">“<!-- -->Their team handled the medical visa, travel plans, and specialist scheduling with professionalism and calm reassurance.<!-- -->”</blockquote><figcaption class=\"mt-6 text-sm font-bold text-teal-200\">Mark Thompson<span class=\"block pt-1 text-xs font-normal text-slate-400\">Oncology patient, Canada</span></figcaption></figure><figure class=\"rounded-2xl border border-white/10 bg-white/5 p-7\"><blockquote class=\"text-sm leading-7 text-slate-200\">“<!-- -->We felt supported at every step, and the medical plan was clear, timely, and focused on recovery.<!-- -->”</blockquote><figcaption class=\"mt-6 text-sm font-bold text-teal-200\">Rashid Islam<span class=\"block pt-1 text-xs font-normal text-slate-400\">Orthopedic patient, Bangladesh</span></figcaption></figure></div></div></section><section class=\"mx-auto max-w-7xl px-5 py-20 lg:px-8\"><div class=\"rounded-[2rem] bg-gradient-to-br from-teal-800 to-cyan-950 px-7 py-14 text-center text-white sm:px-12\"><p class=\"text-sm font-bold uppercase tracking-[.16em] text-teal-200\">A conversation can bring clarity</p><h2 class=\"mx-auto mt-3 max-w-2xl font-display text-4xl font-semibold tracking-tight\">Ready to plan your treatment journey?</h2><p class=\"mx-auto mt-5 max-w-xl text-sm leading-6 text-teal-50/80\">Tell us about your care needs. Our coordinators will help you understand the next practical step.</p><a class=\"mt-8 inline-block rounded-full bg-white px-6 py-3.5 text-sm font-bold text-teal-900 hover:bg-teal-50\" href=\"/contact\">Request a consultation</a></div></section><!--$--><!--/$--></main><footer class=\"bg-slate-950 text-slate-300\"><div class=\"mx-auto grid max-w-7xl gap-10 px-5 py-14 lg:grid-cols-[1.4fr_1fr_1fr_1fr] lg:px-8\"><div><div class=\"flex items-center gap-3 text-white\"><span class=\"grid size-10 place-items-center rounded-xl bg-teal-500 text-xl font-black\">✚</span><strong class=\"font-display\">Shifa Global Care</strong></div><p class=\"mt-5 max-w-sm text-sm leading-6 text-slate-400\">Advancing Healthcare. Building Trust. Transforming Lives.<!-- --> We help international patients navigate treatment in India with clarity, dignity, and ongoing support.</p></div><div><h2 class=\"text-sm font-bold text-white\">Explore</h2><div class=\"mt-4 grid gap-3 text-sm\"><a class=\"hover:text-teal-300\" href=\"/about\">About</a><a class=\"hover:text-teal-300\" href=\"/services\">Services</a><a class=\"hover:text-teal-300\" href=\"/treatments\">Treatments</a><a class=\"hover:text-teal-300\" href=\"/hospitals\">Hospitals</a></div></div><div><h2 class=\"text-sm font-bold text-white\">Patient support</h2><div class=\"mt-4 grid gap-3 text-sm\"><a class=\"hover:text-teal-300\" href=\"/medical-visa\">Medical visa</a><a class=\"hover:text-teal-300\" href=\"/faq\">Frequently asked que