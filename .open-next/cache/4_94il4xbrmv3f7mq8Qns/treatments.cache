{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/treatments/layout,_N_T_/treatments/page,_N_T_/treatments"},"segmentPaths":["/_tree","/_full","/treatments/__PAGE__","/treatments","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/2f4-7bu_b4avd.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/10hl9doanl79t.js\"/><script src=\"/_next/static/chunks/27jktro2p5rq9.js\" async=\"\"></script><script src=\"/_next/static/chunks/352hg3earo7o0.js\" async=\"\"></script><script src=\"/_next/static/chunks/372qajura9dtt.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-24-4cqk2rh9ls.js\" async=\"\"></script><script src=\"/_next/static/chunks/2s5ij6p7395iv.js\" async=\"\"></script><script src=\"/_next/static/chunks/35k-h_1euenzl.js\" async=\"\"></script><script src=\"/_next/static/chunks/1vw862q1ri0sw.js\" async=\"\"></script><title>Shifa Global Care | Healthcare without borders</title><meta name=\"description\" content=\"International medical tourism coordination for treatment in India.\"/><meta name=\"robots\" content=\"index, follow\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><header class=\"fixed inset-x-0 top-0 z-40 border-b border-slate-200/80 bg-white/90 backdrop-blur-xl\"><div class=\"mx-auto flex h-20 max-w-7xl items-center justify-between px-5 lg:px-8\"><a class=\"flex items-center gap-3\" href=\"/\"><span class=\"grid size-10 place-items-center rounded-xl bg-teal-700 text-xl font-black text-white shadow-lg shadow-teal-900/15\">✚</span><span class=\"leading-tight\"><strong class=\"block font-display text-base text-slate-950\">Shifa Global Care</strong><span class=\"text-[10px] font-bold uppercase tracking-[.18em] text-teal-700\">Solution Limited</span></span></a><nav class=\"hidden items-center gap-6 xl:flex\" aria-label=\"Primary navigation\"><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/about\">About</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/services\">Services</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/treatments\">Treatments</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/hospitals\">Hospitals</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/doctors\">Doctors</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/medical-visa\">Medical Visa</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/blog\">Blog</a></nav><div class=\"hidden items-center gap-4 md:flex\"><a class=\"text-sm font-semibold text-slate-700\" href=\"/contact\">Contact us</a><button class=\"rounded-full bg-teal-700 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-teal-900/20 transition hover:bg-teal-800\">Book consultation</button></div><button class=\"grid size-11 place-items-center rounded-xl border border-slate-200 text-xl md:hidden\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">☰</button></div></header><main class=\"pt-20\"><div class=\"min-h-screen bg-slate-50 py-16 px-6\"><div class=\"mx-auto max-w-7xl\"><header class=\"max-w-3xl mb-12\"><span class=\"text-teal-700 font-bold text-xs uppercase tracking-widest block mb-4\">SPECIALTIES &amp; PATHWAYS</span><h1 class=\"text-4xl font-extrabold text-slate-900 tracking-tight sm:text-5xl\">Specialized Treatment Pathways</h1><p class=\"text-base text-slate-600 mt-4 leading-relaxed\">We connect patients with specialized clinical desks in India, managing coordinates for major medical interventions, oncology protocols, organ transplants, and elective surgeries.</p></header><div class=\"flex flex-wrap gap-2 border-b border-slate-200 pb-6 mb-10\"><button class=\"px-4 py-2 text-xs font-semibold rounded-xl transition cursor-pointer bg-teal-700 text-white shadow-xs\">All</button><button class=\"px-4 py-2 text-xs font-semibold rounded-xl transition cursor-pointer text-slate-600 hover:bg-slate-200 hover:text-slate-900\">Critical Care</button><button class=\"px-4 py-2 text-xs font-semibold rounded-xl transition cursor-pointer text-slate-600 hover:bg-slate-200 hover:text-slate-900\">Specialized Surgery</button><button class=\"px-4 py-2 text-xs font-semibold rounded-xl transition cursor-pointer text-slate-600 hover:bg-slate-200 hover:text-slate-900\">Chronic &amp; Organ</button><button class=\"px-4 py-2 text-xs font-semibold rounded-xl transition cursor-pointer text-slate-600 hover:bg-slate-200 hover:text-slate-900\">Wellness &amp; Elective</button></div><div class=\"grid gap-8 md:grid-cols-2 lg:grid-cols-3\"><article class=\"bg-white border border-slate-200 rounded-3xl p-8 shadow-xs hover:shadow-md transition-all flex flex-col justify-between\"><div><div class=\"size-12 rounded-2xl bg-teal-50 text-teal-800 flex items-center justify-center text-xl font-bold mb-6\">❤️</div><h3 class=\"text-lg font-bold text-slate-900 mb-3\">Cardiology</h3><p class=\"text-xs text-slate-500 leading-relaxed mb-6\">Advanced cardiovascular care including minimally invasive heart valve replacements, coronary artery bypass grafts (CABG), angioplasty, and pediatric heart surgeries.</p></div><div class=\"border-t border-slate-100 pt-5 mt-auto\"><h4 class=\"text-2xs font-bold text-slate-400 uppercase tracking-wider mb-3\">Common Procedures:</h4><ul class=\"space-y-2\"><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Bypass Surgery (CABG)</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>TAVR / Valve Replacement</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Angioplasty &amp; Stents</span></li></ul></div></article><article class=\"bg-white border border-slate-200 rounded-3xl p-8 shadow-xs hover:shadow-md transition-all flex flex-col justify-between\"><div><div class=\"size-12 rounded-2xl bg-teal-50 text-teal-800 flex items-center justify-center text-xl font-bold mb-6\">🧬</div><h3 class=\"text-lg font-bold text-slate-900 mb-3\">Oncology</h3><p class=\"text-xs text-slate-500 leading-relaxed mb-6\">Comprehensive cancer therapies ranging from robotic surgeries, radiation therapy (cyberknife), chemotherapy, targeted immunotherapy, and bone marrow transplants.</p></div><div class=\"border-t border-slate-100 pt-5 mt-auto\"><h4 class=\"text-2xs font-bold text-slate-400 uppercase tracking-wider mb-3\">Common Procedures:</h4><ul class=\"space-y-2\"><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Robotic Cancer Surgery</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Immunotherapy &amp; Chemo</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Cyberknife Radiation</span></li></ul></div></article><article class=\"bg-white border border-slate-200 rounded-3xl p-8 shadow-xs hover:shadow-md transition-all flex flex-col justify-between\"><div><div class=\"size-12 rounded-2xl bg-teal-50 text-teal-800 flex items-center justify-center text-xl font-bold mb-6\">🔄</div><h3 class=\"text-lg font-bold text-slate-900 mb-3\">Organ Transplantation</h3><p class=\"text-xs text-slate-500 leading-relaxed mb-6\">State-of-the-art liver and kidney transplantation programs at India&#x27;s leading transplant centers, offering outstanding post-operative survival rates.</p></div><div class=\"border-t border-slate-100 pt-5 mt-auto\"><h4 class=\"text-2xs font-bold text-slate-400 uppercase tracking-wider mb-3\">Common Procedures:</h4><ul class=\"space-y-2\"><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Living Donor Liver Transplant</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Kidney Transplantation</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Bone Marrow Transplant</span></li></ul></div></article><article class=\"bg-white border border-slate-200 rounded-3xl p-8 shadow-xs hover:shadow-md transition-all flex flex-col justify-between\"><div><div class=\"size-12 rounded-2xl bg-teal-50 text-teal-800 flex items-center justify-center text-xl font-bold mb-6\">🧠</div><h3 class=\"text-lg font-bold text-slate-900 mb-3\">Neurology &amp; Neurosurgery</h3><p class=\"text-xs text-slate-500 leading-relaxed mb-6\">Surgical and medical management of brain tumors, deep brain stimulation (DBS) for Parkinson&#x27;s, spinal disc corrections, and stroke rehabilitation.</p></div><div class=\"border-t border-slate-100 pt-5 mt-auto\"><h4 class=\"text-2xs font-bold text-slate-400 uppercase tracking-wider mb-3\">Common Procedures:</h4><ul class=\"space-y-2\"><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Brain Tumor Resection</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Deep Brain Stimulation</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Spinal Fusion Surgery</span></li></ul></div></article><article class=\"bg-white border border-slate-200 rounded-3xl p-8 shadow-xs hover:shadow-md transition-all flex flex-col justify-between\"><div><div class=\"size-12 rounded-2xl bg-teal-50 text-teal-800 flex items-center justify-center text-xl font-bold mb-6\">🦴</div><h3 class=\"text-lg font-bold text-slate-900 mb-3\">Orthopedics &amp; Joint Replacement</h3><p class=\"text-xs text-slate-500 leading-relaxed mb-6\">Highly successful joint reconstruction programs including computer-assisted total knee and hip replacements, arthroscopy, and complex trauma surgeries.</p></div><div class=\"border-t border-slate-100 pt-5 mt-auto\"><h4 class=\"text-2xs font-bold text-slate-400 uppercase tracking-wider mb-3\">Common Procedures:</h4><ul class=\"space-y-2\"><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Total Knee Replacement</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Hip Joint Reconstruction</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Spine Decompression</span></li></ul></div></article><article class=\"bg-white border border-slate-200 rounded-3xl p-8 shadow-xs hover:shadow-md transition-all flex flex-col justify-between\"><div><div class=\"size-12 rounded-2xl bg-teal-50 text-teal-800 flex items-center justify-center text-xl font-bold mb-6\">💧</div><h3 class=\"text-lg font-bold text-slate-900 mb-3\">Gastroenterology &amp; Nephrology</h3><p class=\"text-xs text-slate-500 leading-relaxed mb-6\">Clinical care for complex GI tract disorders, liver cirrhosis, chronic kidney disease (CKD) management, hemodialysis, and renal transplants.</p></div><div class=\"border-t border-slate-100 pt-5 mt-auto\"><h4 class=\"text-2xs font-bold text-slate-400 uppercase tracking-wider mb-3\">Common Procedures:</h4><ul class=\"space-y-2\"><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>GI Endoscopy &amp; Colonoscopy</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Dialysis Services</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Chronic Nephritis Management</span></li></ul></div></article><article class=\"bg-white border border-slate-200 rounded-3xl p-8 shadow-xs hover:shadow-md transition-all flex flex-col justify-between\"><div><div class=\"size-12 rounded-2xl bg-teal-50 text-teal-800 flex items-center justify-center text-xl font-bold mb-6\">👶</div><h3 class=\"text-lg font-bold text-slate-900 mb-3\">Fertility &amp; IVF</h3><p class=\"text-xs text-slate-500 leading-relaxed mb-6\">Advanced reproductive medicine featuring ICSI, egg freezing, pre-implantation genetic diagnostics (PGD), and evidence-based IVF therapies.</p></div><div class=\"border-t border-slate-100 pt-5 mt-auto\"><h4 class=\"text-2xs font-bold text-slate-400 uppercase tracking-wider mb-3\">Common Procedures:</h4><ul class=\"space-y-2\"><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>In Vitro Fertilization (IVF)</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>ICSI Procedures</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Blastocyst Culture</span></li></ul></div></article><article class=\"bg-white border border-slate-200 rounded-3xl p-8 shadow-xs hover:shadow-md transition-all flex flex-col justify-between\"><div><div class=\"size-12 rounded-2xl bg-teal-50 text-teal-800 flex items-center justify-center text-xl font-bold mb-6\">✨</div><h3 class=\"text-lg font-bold text-slate-900 mb-3\">Cosmetic &amp; Reconstructive Surgery</h3><p class=\"text-xs text-slate-500 leading-relaxed mb-6\">Aesthetic and reconstructive procedures focusing on safety, recovery, and natural outcomes, managed by accredited plastic surgeons.</p></div><div class=\"border-t border-slate-100 pt-5 mt-auto\"><h4 class=\"text-2xs font-bold text-slate-400 uppercase tracking-wider mb-3\">Common Procedures:</h4><ul class=\"space-y-2\"><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Reconstructive Surgeries</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Liposuction &amp; Contouring</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Hair Restoration</span></li></ul></div></article><article class=\"bg-white border border-slate-200 rounded-3xl p-8 shadow-xs hover:shadow-md transition-all flex flex-col justify-between\"><div><div class=\"size-12 rounded-2xl bg-teal-50 text-teal-800 flex items-center justify-center text-xl font-bold mb-6\">👁️</div><h3 class=\"text-lg font-bold text-slate-900 mb-3\">Pediatrics &amp; Vision Care</h3><p class=\"text-xs text-slate-500 leading-relaxed mb-6\">Comprehensive pediatric medicine alongside advanced ophthalmology treatments, including corneal transplants, LASIK, and cataract procedures.</p></div><div class=\"border-t border-slate-100 pt-5 mt-auto\"><h4 class=\"text-2xs font-bold text-slate-400 uppercase tracking-wider mb-3\">Common Procedures:</h4><ul class=\"space-y-2\"><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Pediatric Cardiac Care</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>LASIK Eye Correction</span></li><li class=\"flex items-center gap-2 text-2xs text-slate-600\"><span class=\"text-teal-700\">✦</span><span>Corneal Grafting</span></li></ul></div></article></div><div class=\"mt-16 rounded-3xl bg-teal-900 px-8 py-12 text-center text-white relative overflow-hidden shadow-lg\"><div class=\"absolute inset-0 bg-[radial-gradient(circle_at_75%_20%,rgba(20,184,166,0.15),transparent_25%)]\"></div><h2 class=\"text-2xl font-bold mb-3 relative z-10\">Need a Personalized Treatment Plan?</h2><p class=\"mx-auto max-w-xl text-xs text-teal-100 leading-relaxed mb-8 relative z-10\">Speak with our coordinators to review your medical history, expected treatment timeline, and hospital budget before you travel.</p><a class=\"inline-flex rounded-full bg-white text-teal-900 font-bold px-6 py-3.5 text-xs shadow-md hover:bg-slate-50 transition cursor-pointer relative z-10\" href=\"/contact\">Request a Consultation</a></div></div></div><!--$--><!--/$--></main><footer class=\"bg-slate-950 text-slate-300\"><div class=\"mx-auto grid max-w-7xl gap-10 px-5 py-14 lg:grid-cols-[1.4fr_1fr_1fr_1fr] lg:px-8\"><div><div class=\"flex items-center gap-3 text-white\"><span class=\"grid size-10 place-items-center rounded-xl bg-teal-500 text-xl font-black\">✚</span><strong class=\"font-display\">Shifa Global Care</strong></div><p class=\"mt-5 max-w-sm text-sm leading-6 text-slate-400\">Advancing Healthcare. Building Trust. Transforming Lives.<!-- --> We help international patients navigate treatment in India with clarity, dignity, and ongoing support.</p></div><div><h2 class=\"text-sm font-bold text-white\">Explore</h2><div class=\"mt-4 grid gap-3 text-sm\"><a class=\"hover:text-teal-300\" href=\"/about\">About</a><a class=\"hover:text-teal-300\" href=\"/services\">Services</a><a class=\"hover:text-teal-300\" href=\"/treatments\">Treatments</a><a class=\"hover:text-teal-300\" href=\"/hospitals\">Hospitals</a></div></div><div><h2 class=\"text-sm font-bold text-white\">Patient support</h2><div class=\"mt-4 grid gap-3 text-sm\"><a class=\"hover:text-teal-300\" href=\"/medical-visa\">Medical visa</a><a class=\"hover:text-teal-300\" href=\"/faq\">Frequently asked questions</a><a class=\"hover:text-teal-300\" href=\"/contact\">Contact care team</a></div></div><div><h2 class=\"text-sm font-bold text-white\">Important note</h2><p class=\"mt-4 text-sm leading-6 text-slate-400\">Sh