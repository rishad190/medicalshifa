{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/faq/layout,_N_T_/faq/page,_N_T_/faq"},"segmentPaths":["/_tree","/_full","/faq/__PAGE__","/faq","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/2f4-7bu_b4avd.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/10hl9doanl79t.js\"/><script src=\"/_next/static/chunks/27jktro2p5rq9.js\" async=\"\"></script><script src=\"/_next/static/chunks/352hg3earo7o0.js\" async=\"\"></script><script src=\"/_next/static/chunks/372qajura9dtt.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-24-4cqk2rh9ls.js\" async=\"\"></script><script src=\"/_next/static/chunks/2s5ij6p7395iv.js\" async=\"\"></script><script src=\"/_next/static/chunks/35k-h_1euenzl.js\" async=\"\"></script><script src=\"/_next/static/chunks/0gqvvn5i8h6k1.js\" async=\"\"></script><title>Shifa Global Care | Healthcare without borders</title><meta name=\"description\" content=\"International medical tourism coordination for treatment in India.\"/><meta name=\"robots\" content=\"index, follow\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><header class=\"fixed inset-x-0 top-0 z-40 border-b border-slate-200/80 bg-white/90 backdrop-blur-xl\"><div class=\"mx-auto flex h-20 max-w-7xl items-center justify-between px-5 lg:px-8\"><a class=\"flex items-center gap-3\" href=\"/\"><span class=\"grid size-10 place-items-center rounded-xl bg-teal-700 text-xl font-black text-white shadow-lg shadow-teal-900/15\">✚</span><span class=\"leading-tight\"><strong class=\"block font-display text-base text-slate-950\">Shifa Global Care</strong><span class=\"text-[10px] font-bold uppercase tracking-[.18em] text-teal-700\">Solution Limited</span></span></a><nav class=\"hidden items-center gap-6 xl:flex\" aria-label=\"Primary navigation\"><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/about\">About</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/services\">Services</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/treatments\">Treatments</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/hospitals\">Hospitals</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/doctors\">Doctors</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/medical-visa\">Medical Visa</a><a class=\"text-sm font-medium text-slate-600 transition hover:text-teal-700\" href=\"/blog\">Blog</a></nav><div class=\"hidden items-center gap-4 md:flex\"><a class=\"text-sm font-semibold text-slate-700\" href=\"/contact\">Contact us</a><button class=\"rounded-full bg-teal-700 px-5 py-3 text-sm font-bold text-white shadow-lg shadow-teal-900/20 transition hover:bg-teal-800\">Book consultation</button></div><button class=\"grid size-11 place-items-center rounded-xl border border-slate-200 text-xl md:hidden\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">☰</button></div></header><main class=\"pt-20\"><div class=\"min-h-screen bg-slate-50 py-16 px-6\"><div class=\"mx-auto max-w-4xl\"><header class=\"text-center mb-12\"><span class=\"text-teal-700 font-bold text-xs uppercase tracking-widest block mb-4\">HELP CENTER</span><h1 class=\"text-4xl font-extrabold text-slate-900 tracking-tight sm:text-5xl\">Frequently Asked Questions</h1><p class=\"text-sm text-slate-500 mt-4 leading-relaxed max-w-xl mx-auto\">Find answers to common queries about medical travel logistics, visa invitation clearances, payment methods, and treatment coordinates.</p></header><div class=\"flex flex-wrap justify-center gap-2 border-b border-slate-200 pb-6 mb-10\"><button class=\"px-4 py-2 text-xs font-semibold rounded-xl transition cursor-pointer bg-teal-700 text-white shadow-xs\">All</button><button class=\"px-4 py-2 text-xs font-semibold rounded-xl transition cursor-pointer text-slate-600 hover:bg-slate-200 hover:text-slate-900\">General Care</button><button class=\"px-4 py-2 text-xs font-semibold rounded-xl transition cursor-pointer text-slate-600 hover:bg-slate-200 hover:text-slate-900\">Visa &amp; Travel</button><button class=\"px-4 py-2 text-xs font-semibold rounded-xl transition cursor-pointer text-slate-600 hover:bg-slate-200 hover:text-slate-900\">Medical &amp; Safety</button></div><div class=\"space-y-4\"><div class=\"bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-xs hover:border-slate-300 transition-all\"><button class=\"w-full flex justify-between items-center text-left p-6 font-bold text-slate-800 text-sm md:text-base hover:bg-slate-50 transition cursor-pointer focus:outline-none\"><span>How do you select partner hospitals?</span><span class=\"text-teal-700 text-base\">▼</span></button><div class=\"transition-all duration-300 overflow-hidden max-h-0 opacity-0\"><p class=\"p-6 pt-0 text-xs md:text-sm text-slate-500 leading-relaxed border-t border-slate-50\">We coordinate exclusively with hospitals and specialists in India holding JCI (Joint Commission International) or NABH accreditations. We audit clinical success records, emergency support, and international relations desks to ensure safety.</p></div></div><div class=\"bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-xs hover:border-slate-300 transition-all\"><button class=\"w-full flex justify-between items-center text-left p-6 font-bold text-slate-800 text-sm md:text-base hover:bg-slate-50 transition cursor-pointer focus:outline-none\"><span>Do you help with Indian medical visas?</span><span class=\"text-teal-700 text-base\">▼</span></button><div class=\"transition-all duration-300 overflow-hidden max-h-0 opacity-0\"><p class=\"p-6 pt-0 text-xs md:text-sm text-slate-500 leading-relaxed border-t border-slate-50\">Yes, we provide extensive support. We request official Medical Visa Invitation Letters from partner hospitals and review passport/referral details to ensure alignment with embassy guidelines for fast-tracked clearances.</p></div></div><div class=\"bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-xs hover:border-slate-300 transition-all\"><button class=\"w-full flex justify-between items-center text-left p-6 font-bold text-slate-800 text-sm md:text-base hover:bg-slate-50 transition cursor-pointer focus:outline-none\"><span>Can I receive a medical second opinion before traveling?</span><span class=\"text-teal-700 text-base\">▼</span></button><div class=\"transition-all duration-300 overflow-hidden max-h-0 opacity-0\"><p class=\"p-6 pt-0 text-xs md:text-sm text-slate-500 leading-relaxed border-t border-slate-50\">Absolutely. Before any travel coordinates are scheduled, we present your medical charts to senior specialists in our network to provide second opinion reviews, estimated treatment lines, and cost breakdowns.</p></div></div><div class=\"bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-xs hover:border-slate-300 transition-all\"><button class=\"w-full flex justify-between items-center text-left p-6 font-bold text-slate-800 text-sm md:text-base hover:bg-slate-50 transition cursor-pointer focus:outline-none\"><span>Are there any hidden coordination fees?</span><span class=\"text-teal-700 text-base\">▼</span></button><div class=\"transition-all duration-300 overflow-hidden max-h-0 opacity-0\"><p class=\"p-6 pt-0 text-xs md:text-sm text-slate-500 leading-relaxed border-t border-slate-50\">No. Shifa Global Care maintains transparency. Patients pay treatment costs directly to the operating hospital in India. We outline all logistics, guest lodging, and interpreter estimates clearly prior to departure.</p></div></div><div class=\"bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-xs hover:border-slate-300 transition-all\"><button class=\"w-full flex justify-between items-center text-left p-6 font-bold text-slate-800 text-sm md:text-base hover:bg-slate-50 transition cursor-pointer focus:outline-none\"><span>How many companions can travel with the patient?</span><span class=\"text-teal-700 text-base\">▼</span></button><div class=\"transition-all duration-300 overflow-hidden max-h-0 opacity-0\"><p class=\"p-6 pt-0 text-xs md:text-sm text-slate-500 leading-relaxed border-t border-slate-50\">Under the Indian Medical Visa guidelines, up to two family members or attendants can apply for Medical Attendant (MED-2) visas concurrently with the patient. We assist in filing all companion papers.</p></div></div><div class=\"bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-xs hover:border-slate-300 transition-all\"><button class=\"w-full flex justify-between items-center text-left p-6 font-bold text-slate-800 text-sm md:text-base hover:bg-slate-50 transition cursor-pointer focus:outline-none\"><span>What happens after I return to my home country?</span><span class=\"text-teal-700 text-base\">▼</span></button><div class=\"transition-all duration-300 overflow-hidden max-h-0 opacity-0\"><p class=\"p-6 pt-0 text-xs md:text-sm text-slate-500 leading-relaxed border-t border-slate-50\">We schedule regular teleconsultation follow-ups with your operating surgeon and help forward local lab tests or recovery charts back to the hospital. Your Shifa coordinator remains available for care continuity.</p></div></div></div><div class=\"mt-16 text-center border-t border-slate-200 pt-8\"><p class=\"text-xs text-slate-500\">Still have questions? Contact our dedicated 24/7 care coordination desk.</p><div class=\"mt-4 flex flex-wrap justify-center gap-4 text-xs font-bold text-teal-700\"><div>✉ info@shifaglobal.care</div><div>📞 +91 98765 43210</div></div></div></div></div><!--$--><!--/$--></main><footer class=\"bg-slate-950 text-slate-300\"><div class=\"mx-auto grid max-w-7xl gap-10 px-5 py-14 lg:grid-cols-[1.4fr_1fr_1fr_1fr] lg:px-8\"><div><div class=\"flex items-center gap-3 text-white\"><span class=\"grid size-10 place-items-center rounded-xl bg-teal-500 text-xl font-black\">✚</span><strong class=\"font-display\">Shifa Global Care</strong></div><p class=\"mt-5 max-w-sm text-sm leading-6 text-slate-400\">Advancing Healthcare. Building Trust. Transforming Lives.<!-- --> We help international patients navigate treatment in India with clarity, dignity, and ongoing support.</p></div><div><h2 class=\"text-sm font-bold text-white\">Explore</h2><div class=\"mt-4 grid gap-3 text-sm\"><a class=\"hover:text-teal-300\" href=\"/about\">About</a><a class=\"hover:text-teal-300\" href=\"/services\">Services</a><a class=\"hover:text-teal-300\" href=\"/treatments\">Treatments</a><a class=\"hover:text-teal-300\" href=\"/hospitals\">Hospitals</a></div></div><div><h2 class=\"text-sm font-bold text-white\">Patient support</h2><div class=\"mt-4 grid gap-3 text-sm\"><a class=\"hover:text-teal-300\" href=\"/medical-visa\">Medical visa</a><a class=\"hover:text-teal-300\" href=\"/faq\">Frequently asked questions</a><a class=\"hover:text-teal-300\" href=\"/contact\">Contact care team</a></div></div><div><h2 class=\"text-sm font-bold text-white\">Important note</h2><p class=\"mt-4 text-sm leading-6 text-slate-400\">Shifa coordinates care but does not replace advice from a licensed clinician. For urgent symptoms, seek local emergency care.</p></div></div><div class=\"border-t border-white/10\"><div class=\"mx-auto flex max-w-7xl flex-col gap-3 px-5 py-5 text-xs text-slate-500 sm:flex-row sm:justify-between lg:px-8\"><span>© <!-- -->2026<!-- --> Shifa Global Care Solution Limited.</span><span><a class=\"hover:text-white\" href=\"/privacy-policy\">Privacy</a> · <a class=\"hover:text-white\" href=\"/terms\">Terms</a></span></div></div></footer><script src=\"/_next/static/chunks/10hl9doanl79t.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[70119,[\\\"/_next/static/chunks/2s5ij6p7395iv.js\\\",\\\"/_next/static/chunks/35k-h_1euenzl.js\\\"],\\\"default\\\"]\\n3:I[39756,[\\\"/_next/static/chunks/2s5ij6p7395iv.js\\\",\\\"/_next/static/chunks/35k-h_1euenzl.js\\\"],\\\"default\\\"]\\n4:I[37457,[\\\"/_next/static/chunks/2s5ij6p7395iv.js\\\",\\\"/_next/static/chunks/35k-h_1euenzl.js\\\"],\\\"default\\\"]\\n5:I[22016,[\\\"/_next/static/chunks/2s5ij6p7395iv.js\\\",\\\"/_next/static/chunks/35k-h_1euenzl.js\\\"],\\\"\\\"]\\nd:I[68027,[\\\"/_next/static/chunks/2s5ij6p7395iv.js\\\",\\\"/_next/static/chunks/35k-h_1euenzl.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/2f4-7bu_b4avd.css\\\",\\\"style\\\"]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\":null,\\\"c\\\":[\\\"\\\",\\\"faq\\\"],\\\"q\\\":\\\"\\\",\\\"i\\\":false,\\\"f\\\":[[[\\\"\\\",{\\\"children\\\":[\\\"faq\\\",{\\\"children\\\":[\\\"__PAGE__\\\",{}]}]},\\\"$undefined\\\",\\\"$undefined\\\",16],[[\\\"$\\\",\\\"$1\\\",\\\"c\\\",{\\\"children\\\":[[[\\\"$\\\",\\\"link\\\",\\\"0\\\",{\\\"rel\\\":\\\"stylesheet\\\",\\\"href\\\":\\\"/_next/static/chunks/2f4-7bu_b4avd.css\\\",\\\"precedence\\\":\\\"next\\\",\\\"crossOrigin\\\":\\\"$undefined\\\",\\\"nonce\\\":\\\"$undefined\\\"}],[\\\"$\\\",\\\"script\\\",\\\"script-0\\\",{\\\"src\\\":\\\"/_next/static/chunks/2s5ij6p7395iv.js\\\",\\\"async\\\":true,\\\"nonce\\\":\\\"$undefined\\\"}],[\\\"$\\\",\\\"script\\\",\\\"script-1\\\",{\\\"src\\\":\\\"/_next/static/chunks/35k-h_1euenzl.js\\\",\\\"async\\\":true,\\\"nonce\\\":\\\"$undefined\\\"}]],[\\\"$\\\",\\\"html\\\",null,{\\\"lang\\\":\\\"en\\\",\\\"children\\\":[\\\"$\\\",\\\"body\\\",null,{\\\"ch